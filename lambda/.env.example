# GradeEarn — Lambda environment variable inventory
# ====================================================
# This file is documentation only. Values live in:
#   - AWS Lambda function env vars (per function)
#   - AWS Secrets Manager (for the actual API keys + auth signing key)
# Never commit real values. Never `source` this file in production.
#
# Format: KEY=  # one-line description (default in code if any)
#
# Inventory generated by inspecting `process.env.*` references in the
# deployed-equivalent source: lambda/tutor-build/, lambda/pool-topup/,
# lambda/quality-patrol/, lambda/content-lake.js. Last verified
# against AWS account 860141646209 us-east-1 on 2026-05-02.


# ============================================================
# staar-tutor (the only API-facing lambda)
# ============================================================

# --- Core (REQUIRED — set in AWS today) ---
ADMIN_USERNAMES=         # comma-separated lowercase usernames with admin rights
AUTH_SECRET_NAME=        # Secrets Manager id, e.g. staar-tutor/auth-secret (HMAC token signing key)
OPENAI_MODEL=            # e.g. gpt-4o-mini
OPENAI_SECRET_NAME=      # Secrets Manager id, e.g. staar-tutor/openai-api-key
USERS_TABLE=             # DynamoDB table for student profiles  (default in code: staar-users)
STATS_TABLE=             # DynamoDB table for per-user stats     (default in code: staar-stats)
TOYS_TABLE=              # DynamoDB table for toy catalog        (default in code: staar-toys)
ORDERS_TABLE=            # DynamoDB table for orders             (default in code: staar-orders)
S3_TOY_BUCKET=           # S3 bucket name for toy images / presigned uploads. NO default in code — required.

# --- Referenced in code but NOT currently set in AWS (defaults are used) ---
# These all have working defaults in the source. Set them explicitly only if
# you want to point the lambda at a non-default table/origin.
ALLOWED_ORIGIN=          # CORS allow-origin; defaults to "*"
AWS_REGION=              # set automatically by Lambda runtime; do not set manually
FRIENDS_TABLE=           # default in code: staar-friends
MESSAGES_TABLE=          # default in code: staar-messages

# --- Used by content-lake.js (bundled into staar-tutor zip) ---
POOL_TABLE=              # default in code: staar-content-pool
EXPLANATIONS_TABLE=      # default in code: staar-explanations
EVENTS_TABLE=            # default in code: staar-content-events
TUTOR_TABLE=             # default in code: staar-tutor-responses


# ============================================================
# staar-pool-topup (background — hourly EventBridge — CURRENTLY DISABLED)
# ============================================================
# Note: index.js fetches the OpenAI key from Secrets Manager
# (staar-tutor/openai-api-key) and sets process.env.OPENAI_API_KEY at
# runtime for generators.js. So OPENAI_API_KEY does NOT need to be set
# in the AWS function env. Listed here for completeness.
#
# OPENAI_API_KEY=         # set at runtime by handler from Secrets Manager — do not set externally


# ============================================================
# staar-quality-patrol (background — daily EventBridge — CURRENTLY DISABLED)
# ============================================================
# No env vars referenced in source. All table names are hardcoded in
# index.js (staar-content-pool). Nothing to configure.


# ============================================================
# Local development (cold-start scripts)
# ============================================================
# scripts/cold-start/sweep-math.sh sources /tmp/.openai_env which must export:
#
# OPENAI_API_KEY=         # OpenAI API key for local bulk question generation
#
# This is intentionally outside the repo to avoid checking it in.
