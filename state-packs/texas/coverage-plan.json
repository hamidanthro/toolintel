  "_meta": {
    "subject": "math",
    "version": "1.0",
    "built": "2026-05-03",
    "authority": "Texas Education Agency / GradeEarn",
    "purpose": "Per-bucket fill targets weighted by STAAR frequency. Drives the §35 coverage-audit gap analysis and the next-sweep priority order.",
    "weighting_rationale": "Tier per TEKS based on observed STAAR-released-form frequency. HEAVY = appears multiply on every released form. STANDARD = appears on most forms. LIGHT = niche / appears occasionally. TEXAS_SPECIFIC = personal-financial-literacy strand (Texas signature; not covered by Common Core / other states).",
    "unit": "rows per (grade × TEKS × question-type) bucket",
    "question_types": ["word-problem", "computation", "concept", "data-interpretation"],
    "default_tier": "standard",
    "provenance_marker": "[CLAUDE-SYNTHESIZED tier assignments per STAAR observation. Not authoritative; verify against TEA scoring weights when published. Hamid signed off on the per-tier numeric ranges 2026-05-03.]"
  },

  "tiers": {
    "heavy": {
      "target_per_type": 100,
      "range": [100, 120],
      "description": "Foundational, high-frequency on every released STAAR form. Multiple items per form. Drives the headline pass rate."
    },
    "standard": {
      "target_per_type": 60,
      "range": [50, 80],
      "description": "Regular STAAR appearance. One or more items per form."
    },
    "light": {
      "target_per_type": 40,
      "range": [30, 50],
      "description": "Niche topics. Appears occasionally; one item per form at most."
    },
    "texas_specific": {
      "target_per_type": 40,
      "range": [30, 50],
      "description": "Texas Personal Financial Literacy strand (3.9 / 4.10 / 5.10 / 6.14 / 7.13 / 8.12). Texas signature; not in Common Core."
    }
  },

